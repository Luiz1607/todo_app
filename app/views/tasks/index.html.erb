<section class="page-header">
  <h2>Minha To-Do List</h2>
  <%= link_to "Nova tarefa", new_task_path, class: "btn btn-primary" %>
</section>

<% if @tasks.any? %>
  <ul class="task-list">
    <% @tasks.each do |task| %>
      <li class="task-card">
        <div class="task-title-row">
          <strong><%= task.title %></strong>
          <% if task.done %>
            <span class="badge badge-done">Concluída</span>
          <% else %>
            <span class="badge badge-pending">Pendente</span>
          <% end %>
        </div>

        <% if task.description.present? %>
          <p class="task-description"><%= task.description %></p>
        <% end %>

        <% if task.due_date.present? %>
          <p class="task-meta">Prazo: <%= task.due_date %></p>
        <% end %>

        <div class="task-actions">
          <%= link_to "Ver", task_path(task), class: "btn btn-secondary btn-sm" %>
          <%= link_to "Editar", edit_task_path(task), class: "btn btn-secondary btn-sm" %>
          <%= button_to "Excluir", task_path(task), method: :delete, class: "btn btn-danger btn-sm", form: { class: "inline-form" } %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="empty-state">Nenhuma tarefa cadastrada ainda.</p>
<% end %>
